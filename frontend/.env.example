# ==========================================
# VARIABLES DE ENTORNO - FRONTEND (Vite)
# ==========================================
# Instrucciones: Copia este archivo como '.env' y completa con tus credenciales reales.
# Nota: En Vite, todas las variables expuestas al navegador deben tener el prefijo 'VITE_'.

# 1. Supabase (Base de Datos y Autenticación)
# URL de la instancia del proyecto en Supabase (ej. https://abcdefghijkl.supabase.co)
VITE_SUPABASE_URL=tu_url_de_supabase_aqui

# Clave pública 'anon' de Supabase (necesaria para el cliente Supabase-js y peticiones públicas)
VITE_SUPABASE_ANON_KEY=tu_clave_anon_de_supabase_aqui

# 2. Conexión a la API (Backend Fastify)
# URL base donde corre el servidor Fastify. Por defecto en desarrollo es localhost:3000
VITE_API_URL=http://localhost:3000
